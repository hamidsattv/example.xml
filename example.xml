<widget source="session.FrontendStatus" render="Progress" position="710,534" size="200,6" backgroundColor="#002d2d2d" foregroundGradient="red, yellow, green, horizontal" transparent="1" zPosition="5" cornerRadius="3">
  <convert type="FrontendInfo">AGC</convert>
</widget>
<widget source="session.FrontendStatus" render="Label" position="920,525" size="65,20" font="Regular; 18" backgroundColor="layer-b-background" halign="left" transparent="1">
  <convert type="FrontendInfo">AGC</convert>
</widget>
	</screen>
	<screen name="#deactivated#CHANNELNAMEMOD">
<!--
		#description#channel name mod for infobar by MNASR
		#previewfile#channel name mod.png
/-->
<widget font="Regular; 42" backgroundColor="text-background" foregroundColor="background-text" noWrap="1" position="30,488" render="Label" size="1252,46" source="session.CurrentService" transparent="1" valign="bottom" zPosition="-30">
		<convert type="MetrixHDExtServiceInfo">ServiceNumberAndName</convert>
</widget>
	</screen>
</skin>

